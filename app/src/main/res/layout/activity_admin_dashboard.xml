<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/adminName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Name"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/adminStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Super Admin"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/adminLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:backgroundTint="#D32F2F"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp"
            app:cornerRadius="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="8dp">

                <!-- Students -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/border_gray"
                    android:layout_margin="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Students"
                        android:textColor="#3F51B5"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalStudents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- Admins -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/border_gray"
                    android:layout_margin="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admins"
                        android:textColor="#3F51B5"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalAdmins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- Lecturers -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/border_gray"
                    android:layout_margin="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lecturers"
                        android:textColor="#3F51B5"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalLecturers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- Courses -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/border_gray"
                    android:layout_margin="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Courses"
                        android:textColor="#3F51B5"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalCourses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- GPS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/border_gray"
                    android:layout_margin="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS"
                        android:textColor="#3F51B5"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalGPS"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnAddStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Student"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnAddLecturer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Lecturer"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnAddAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Admin"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnAddCourse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Course"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnAddGPS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add GPS/Venue"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</ScrollView>